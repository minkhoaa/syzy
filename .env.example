# ===========================================
# Syzy Environment Configuration
# ===========================================
# Copy this file to .env and fill in values

# ===========================================
# Database
# ===========================================
POSTGRES_USER=syzy
POSTGRES_PASSWORD=your-secure-password
POSTGRES_DB=syzy_waitlist

# ===========================================
# Redis
# ===========================================
REDIS_URL=redis://redis:6379

# ===========================================
# Backend API
# ===========================================
NODE_ENV=production
PORT=7788

# Email (Resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=admin@syzy.space

# App Settings
WAITLIST_APP_ORIGIN=https://syzy.space
WAITLIST_APP_DOMAIN=syzy.space

# JWT Secrets (generate with: openssl rand -base64 32)
WAITLIST_MEMBER_JWT_SECRET=
WAITLIST_ADMIN_JWT_SECRET=
WAITLIST_MEMBER_REFRESH_SECRET=
WAITLIST_ADMIN_REFRESH_SECRET=

# ===========================================
# Frontend (Next.js)
# ===========================================
NEXT_PUBLIC_API_URL=https://api.syzy.space
NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_REOWN_PROJECT_ID=
NEXT_PUBLIC_PROGRAM_ID=
NEXT_PUBLIC_WAITLIST_API_URL=https://api.syzy.space

# ===========================================
# Docker Images (Production)
# ===========================================
BACKEND_IMAGE=ghcr.io/minkhoaa/syzy/syzy-backend:latest
FRONTEND_IMAGE=ghcr.io/minkhoaa/syzy/syzy-frontend:latest

# ===========================================
# GitHub Actions Secrets (for CI/CD)
# ===========================================
# SSH_HOST=206.189.151.6
# SSH_PRIVATE_KEY=<your-private-key>
# GHCR_TOKEN=<github-pat-with-packages-access>
