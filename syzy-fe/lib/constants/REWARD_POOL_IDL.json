          },
          {
            "name": "total_staked",
            "docs": [
              "Total OYRADE tokens staked across all users"
            ],
            "type": "u64"
          },
          {
            "name": "reward_per_token_stored",
            "docs": [
              "Accumulated reward per staked token (scaled by PRECISION)",
              "reward_per_token += (elapsed * reward_rate * PRECISION) / total_staked"
            ],
            "type": "u128"
          },
          {
            "name": "reward_rate",
            "docs": [
              "SOL reward distributed per second (lamports/second)"
            ],
            "type": "u64"
          },
          {
            "name": "reward_duration",
