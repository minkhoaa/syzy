              "Reward distribution duration in seconds"
            ],
            "type": "u64"
          },
          {
            "name": "reward_duration_end",
            "docs": [
              "Timestamp when current reward period ends"
            ],
            "type": "u64"
          },
          {
            "name": "last_update_time",
            "docs": [
              "Last time reward_per_token_stored was updated"
            ],
            "type": "u64"
          },
          {
            "name": "bump",
            "docs": [
              "PDA bump for the pool account"
            ],
            "type": "u8"
          },
          {
            "name": "reward_vault_bump",
            "docs": [
              "PDA bump for the reward vault"
            ],
            "type": "u8"
          },
          {
            "name": "paused",
            "docs": [
              "Emergency pause flag — blocks stake/unstake/claim when true"
            ],
            "type": "bool"
          },
          {
            "name": "funders",
            "docs": [
              "List of authorized funders (addresses allowed to call `fund`)"
            ],
            "type": {
              "array": [
                "pubkey",
                5
              ]
            }
          }
        ]
      }
