      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "authority",
            "docs": [
              "Authority that can manage the pool"
            ],
            "type": "pubkey"
          },
          {
            "name": "staking_mint",
            "docs": [
              "The OYRADE SPL token mint"
            ],
            "type": "pubkey"
          },
          {
