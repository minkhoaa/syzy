# Database
POSTGRES_USER=syzy
POSTGRES_PASSWORD=your-secure-password-here
POSTGRES_DB=syzy_waitlist

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=admin@syzy.space

# App URLs
WAITLIST_APP_ORIGIN=https://syzy.space
WAITLIST_APP_DOMAIN=syzy.space

# JWT Secrets (generate with: openssl rand -base64 32)
WAITLIST_MEMBER_JWT_SECRET=your-32-char-secret-here-minimum
WAITLIST_ADMIN_JWT_SECRET=your-32-char-secret-here-minimum
WAITLIST_MEMBER_REFRESH_SECRET=your-32-char-refresh-secret
WAITLIST_ADMIN_REFRESH_SECRET=your-32-char-refresh-secret

# Docker images (set by CI/CD, or use these defaults)
BACKEND_IMAGE=ghcr.io/morcalabs/syzy/syzy-backend:latest
FRONTEND_IMAGE=ghcr.io/morcalabs/syzy/syzy-frontend:latest
